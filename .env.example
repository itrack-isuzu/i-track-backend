PORT=4000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?appName=Itrack
MONGODB_DB_NAME=itrack
CLIENT_ORIGIN=*
MONGODB_AUTO_CREATE_COLLECTIONS=true
MONGODB_AUTO_SEED=false

# EmailJS password recovery
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=public_xxxxxxxxxxxxx
EMAILJS_PRIVATE_KEY=
EMAILJS_APP_NAME=I-TRACK
EMAILJS_SUPPORT_EMAIL=support@itrack.com
EXPO_ACCESS_TOKEN=

# SMS notifications
SMS_ENABLED=true
SMS_PROVIDER=fortmed

# Fortmed provider
FORTMED_API_URL=https://api.fortmedph.com/api/public/v1/sms/send
FORTMED_API_KEY=fmcsms_5048442cd938a83e22572580ae7ad4d77d3aa283bcf3b93d
FORTMED_SENDER_ID=I-Track
FORTMED_FROM_NUMBER=09676767676

# Legacy Fortmed aliases still supported by the backend
# SMS_API_URL=
# SMS_API_KEY=
# SMS_SENDER_ID=
# SMS_FROM_NUMBER=

# FMCSMS / older gateway style provider
# FMCSMS_API_URL=http://www.ciedco-sms.net/api/sendsms.php
# FMCSMS_USERNAME=
# FMCSMS_PASSWORD=
# FMCSMS_SENDER_ID=

# Twilio fallback / hosted provider
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_FROM_NUMBER=

# Preparation ETA AI
PREPARATION_ETA_AI_ENABLED=true
PREPARATION_ETA_AI_URL=https://itrack-machinelearning.onrender.com
PREPARATION_ETA_AI_KEY=itrack-ml-secret-2026
PREPARATION_ETA_MODEL_SYNC_KEY=itrack-model-sync-secret-2026

PASSWORD_RESET_OTP_EXPIRES_MINUTES=10
PASSWORD_RESET_OTP_COOLDOWN_SECONDS=60
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
