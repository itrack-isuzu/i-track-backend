PORT=4000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?appName=Itrack
MONGODB_DB_NAME=itrack
CLIENT_ORIGIN=*
MONGODB_AUTO_CREATE_COLLECTIONS=true
MONGODB_AUTO_SEED=false

# EmailJS password recovery
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=public_xxxxxxxxxxxxx
EMAILJS_PRIVATE_KEY=
EMAILJS_APP_NAME=I-TRACK
EMAILJS_SUPPORT_EMAIL=support@itrack.com
PASSWORD_RESET_OTP_EXPIRES_MINUTES=10
PASSWORD_RESET_OTP_COOLDOWN_SECONDS=60
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
